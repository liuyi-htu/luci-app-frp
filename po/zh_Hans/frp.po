msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"MIME-Version: 1.0\n"
"Project-Id-Version: luci-app-frp\n"
"Language: zh_Hans\n"
"Plural-Forms: nplurals=1; plural=0;\n"

msgid "-- Please choose --"
msgstr "-- 请选择 --"

msgid "Add new proxy..."
msgstr "添加新代理..."

msgid "Additional INI configs"
msgstr "附加 INI 配置文件"

msgid "Additional settings"
msgstr "附加设置"

msgid "Admin address"
msgstr "管理接口地址"

msgid "Admin password"
msgstr "管理接口密码"

msgid "Admin port"
msgstr "管理接口端口"

msgid "Admin user"
msgstr "管理接口用户名"

msgid "AdminAddr specifies the address that the admin server binds to.<br />By default, this value is \"0.0.0.0\"."
msgstr "AdminAddr 指定管理接口绑定的地址。<br />默认值为 \"0.0.0.0\"。"

msgid "AdminPort specifies the port for the admin server to listen on. If this value is 0, the admin server will not be started.<br />By default, this value is 0."
msgstr "AdminPort 指定管理接口监听的端口。如果此值为 0，则不会启动管理接口。<br />默认值为 0。"

msgid "AdminPwd specifies the password that the admin server will use for login.<br />By default, this value is \"admin\"."
msgstr "AdminPwd 指定登录管理接口时使用的密码。<br />默认值为 \"admin\"。"

msgid "AdminUser specifies the username that the admin server will use for login.<br />By default, this value is \"admin\"."
msgstr "AdminUser 指定登录管理接口时使用的用户名。<br />默认值为 \"admin\"。"

msgid "Allow ports"
msgstr "允许代理端口"

msgid "AllowPorts specifies a set of ports that clients are able to proxy to. If the length of this value is 0, all ports are allowed.<br />By default, this value is an empty set."
msgstr "AllowPorts 指定客户端可以代理的端口集合。如果此值为空，则允许所有端口。<br />默认值为空集合。"

msgid "Assets dir"
msgstr "静态资源目录"

msgid "AssetsDir specifies the local directory that the admin server will load resources from. If this value is \"\", assets will be loaded from the bundled executable using statik.<br />By default, this value is \"\"."
msgstr "AssetsDir 指定管理接口加载静态资源的本地目录。如果此值为 \"\"，则使用 statik 从内置可执行文件加载资源。<br />默认值为 \"\"。"

msgid "AssetsDir specifies the local directory that the dashboard will load resources from. If this value is \"\", assets will be loaded from the bundled executable using statik.<br />By default, this value is \"\"."
msgstr "AssetsDir 指定控制台加载静态资源的本地目录。如果此值为 \"\"，则使用 statik 从内置可执行文件加载资源。<br />默认值为 \"\"。"

msgid "Bind addr"
msgstr "绑定地址"

msgid "Bind address"
msgstr "绑定地址"

msgid "Bind port"
msgstr "绑定端口"

msgid "BindAddr specifies the address that the server binds to.<br />By default, this value is \"0.0.0.0\"."
msgstr "BindAddr 指定服务端绑定的地址。<br />默认值为 \"0.0.0.0\"。"

msgid "BindKcpPort specifies the KCP port that the server listens on. If this value is 0, the server will not listen for KCP connections.<br />By default, this value is 0."
msgstr "BindKcpPort 指定服务端监听的 KCP 端口。如果此值为 0，服务端将不会监听 KCP 连接。<br />默认值为 0。"

msgid "BindPort specifies the port that the server listens on.<br />By default, this value is 7000."
msgstr "BindPort 指定服务端监听的端口。<br />默认值为 7000。"

msgid "BindQuicPort specifies the QUIC port that the server listens on. If this value is 0, the server will not listen for QUIC connections.<br />By default, this value is 0."
msgstr "BindQuicPort 指定服务端监听的 QUIC 端口。如果此值为 0，服务端将不会监听 QUIC 连接。<br />默认值为 0。"

msgid "BindUdpPort specifies the UDP port that the server listens on. If this value is 0, the server will not listen for UDP connections.<br />By default, this value is 0."
msgstr "BindUdpPort 指定服务端监听的 UDP 端口。如果此值为 0，服务端将不会监听 UDP 连接。<br />默认值为 0。"

msgid "Client Common Settings"
msgstr "客户端常规设置"

msgid "Client Proxy Settings"
msgstr "客户端代理设置"

msgid "Client Startup Settings"
msgstr "客户端启动设置"

msgid "Collecting data ..."
msgstr "正在获取状态..."

msgid "Command failed"
msgstr "命令执行失败"

msgid "Compression"
msgstr "压缩"

msgid "Custom 404 page"
msgstr "自定义 404 页面"

msgid "Custom domains"
msgstr "自定义域名"

msgid "Custom404Page specifies a path to a custom 404 page to display. If this value is \"\", a default page will be displayed.<br />By default, this value is \"\"."
msgstr "Custom404Page 指定要显示的自定义 404 页面路径。如果此值为 \"\"，则显示默认页面。<br />默认值为 \"\"。"

msgid "Dashboard address"
msgstr "控制台地址"

msgid "Dashboard password"
msgstr "控制台密码"

msgid "Dashboard port"
msgstr "控制台端口"

msgid "Dashboard TLS Cert File specifies the path to the TLS certificate file for enabling HTTPS access.<br />Required if HTTPS is enabled."
msgstr "Dashboard TLS Cert File 指定启用 HTTPS 访问控制台时使用的 TLS 证书文件路径。<br />启用 HTTPS 时必填。"

msgid "Dashboard TLS certificate"
msgstr "控制台 TLS 证书"

msgid "Dashboard TLS Key File specifies the path to the TLS private key file for enabling HTTPS access.<br />Required if HTTPS is enabled."
msgstr "Dashboard TLS Key File 指定启用 HTTPS 访问控制台时使用的 TLS 私钥文件路径。<br />启用 HTTPS 时必填。"

msgid "Dashboard TLS mode"
msgstr "控制台 TLS 模式"

msgid "Dashboard TLS private key"
msgstr "控制台 TLS 私钥"

msgid "Dashboard user"
msgstr "控制台用户名"

msgid "DashboardAddr specifies the address that the dashboard binds to.<br />By default, this value is \"0.0.0.0\"."
msgstr "DashboardAddr 指定控制台绑定的地址。<br />默认值为 \"0.0.0.0\"。"

msgid "DashboardPort specifies the port that the dashboard listens on. If this value is 0, the dashboard will not be started.<br />By default, this value is 0."
msgstr "DashboardPort 指定控制台监听的端口。如果此值为 0，则不会启动控制台。<br />默认值为 0。"

msgid "DashboardPwd specifies the password that the dashboard will use for login.<br />By default, this value is \"admin\"."
msgstr "DashboardPwd 指定登录控制台时使用的密码。<br />默认值为 \"admin\"。"

msgid "DashboardUser specifies the username that the dashboard will use for login.<br />By default, this value is \"admin\"."
msgstr "DashboardUser 指定登录控制台时使用的用户名。<br />默认值为 \"admin\"。"

msgid "Disable log color"
msgstr "禁用日志颜色"

msgid "DisableLogColor disables log colors when LogWay == \"console\" when set to true."
msgstr "当 LogWay == \"console\" 且此项为 true 时，DisableLogColor 会禁用日志颜色。"

msgid "DisableLogColor disables log colors when LogWay == \"console\" when set to true.<br />By default, this value is false."
msgstr "当 LogWay == \"console\" 且此项为 true 时，DisableLogColor 会禁用日志颜色。<br />默认值为 false。"

msgid "Enable or disable TLS encryption for the dashboard. When enabled, HTTPS is used for secure communication."
msgstr "启用或禁用控制台的 TLS 加密。启用后，将使用 HTTPS 进行安全通信。"

msgid "Encryption"
msgstr "加密"

msgid "Environment variable"
msgstr "环境变量"

msgid "Exit when login fail"
msgstr "登录失败后退出"

msgid "Failed to execute \"/etc/init.d/%s %s\" action: %s"
msgstr "执行 \"/etc/init.d/%s %s\" 操作失败：%s"

msgid "frp Client"
msgstr "frp 客户端"

msgid "frp Intranet Proxy"
msgstr "frp 内网穿透"

msgid "frp Server"
msgstr "frp 服务端"

msgid "General Settings"
msgstr "常规设置"

msgid "Heartbeat interval"
msgstr "心跳间隔"

msgid "Heartbeat timeout"
msgstr "心跳超时"

msgid "HeartBeatInterval specifies at what interval heartbeats are sent to the server, in seconds. It is not recommended to change this value.<br />By default, this value is 30."
msgstr "HeartBeatInterval 指定客户端向服务端发送心跳的间隔，单位为秒。不建议修改此值。<br />默认值为 30。"

msgid "HeartBeatTimeout specifies the maximum allowed heartbeat response delay before the connection is terminated, in seconds. It is not recommended to change this value.<br />By default, this value is 90."
msgstr "HeartBeatTimeout 指定连接终止前允许的最大心跳响应延迟，单位为秒。不建议修改此值。<br />默认值为 90。"

msgid "HeartBeatTimeout specifies the maximum time to wait for a heartbeat before terminating the connection. It is not recommended to change this value.<br />By default, this value is 90."
msgstr "HeartBeatTimeout 指定终止连接前等待心跳的最长时间，单位为秒。不建议修改此值。<br />默认值为 90。"

msgid "Host header rewrite"
msgstr "重写 Host 请求头"

msgid "HTTP password"
msgstr "HTTP 密码"

msgid "HTTP proxy"
msgstr "HTTP 代理"

msgid "HTTP Settings"
msgstr "HTTP 设置"

msgid "HTTP user"
msgstr "HTTP 用户名"

msgid "HttpProxy specifies a proxy address to connect to the server through. If this value is \"\", the server will be connected to directly.<br />By default, this value is read from the \"http_proxy\" environment variable."
msgstr "HttpProxy 指定通过代理连接到服务端的代理地址。如果此值为 \"\"，则直接连接服务端。<br />默认情况下，此值从 \"http_proxy\" 环境变量读取。"

msgid "If remote_port is 0, frps will assign a random port for you"
msgstr "如果 remote_port 为 0，frps 将自动分配一个随机端口"

msgid "INI config files include in temporary config file"
msgstr "要合并到临时配置文件中的 INI 配置文件"

msgid "KCP bind port"
msgstr "KCP 绑定端口"

msgid "Local IP"
msgstr "本地 IP"

msgid "Local port"
msgstr "本地端口"

msgid "LocalIp specifies the IP address or host name to proxy to."
msgstr "LocalIp 指定要代理到的 IP 地址或主机名。"

msgid "LocalPort specifies the port to proxy to."
msgstr "LocalPort 指定要代理到的端口。"

msgid "Locations"
msgstr "URL 路径"

msgid "Log file"
msgstr "日志文件"

msgid "Log level"
msgstr "日志等级"

msgid "Log max days"
msgstr "日志保留天数"

msgid "Log stderr"
msgstr "记录标准错误"

msgid "Log stdout"
msgstr "记录标准输出"

msgid "LogFile specifies a file where logs will be written to. This value will only be used if LogWay is set appropriately.<br />By default, this value is \"console\"."
msgstr "LogFile 指定日志写入的文件。只有在 LogWay 设置为相应输出方式时才会使用此值。<br />默认值为 \"console\"。"

msgid "LoginFailExit controls whether or not the client should exit after a failed login attempt. If false, the client will retry until a login attempt succeeds.<br />By default, this value is true."
msgstr "LoginFailExit 控制客户端登录失败后是否退出。如果为 false，客户端将持续重试直到登录成功。<br />默认值为 true。"

msgid "LogLevel specifies the minimum log level. Valid values are \"trace\", \"debug\", \"info\", \"warn\", and \"error\".<br />By default, this value is \"info\"."
msgstr "LogLevel 指定最低日志等级。有效值为 \"trace\"、\"debug\"、\"info\"、\"warn\" 和 \"error\"。<br />默认值为 \"info\"。"

msgid "LogMaxDays specifies the maximum number of days to store log information before deletion. This is only used if LogWay == \"file\".<br />By default, this value is 0."
msgstr "LogMaxDays 指定删除前保留日志信息的最大天数。仅当 LogWay == \"file\" 时使用。<br />默认值为 0。"

msgid "Max ports per client"
msgstr "每个客户端最大端口数"

msgid "MaxPortsPerClient specifies the maximum number of ports a single client may proxy to. If this value is 0, no limit will be applied.<br />By default, this value is 0."
msgstr "MaxPortsPerClient 指定单个客户端可代理的最大端口数。如果此值为 0，则不限制。<br />默认值为 0。"

msgid "OS environments pass to frp for config file template, see %s."
msgstr "传递给 frp 配置模板的系统环境变量，参见 %s。"

msgid "Plugin"
msgstr "插件"

msgid "Plugin Settings"
msgstr "插件设置"

msgid "Protocol"
msgstr "协议"

msgid "Protocol specifies the protocol to use when interacting with the server. Valid values are \"tcp\", \"kcp\", \"quic\" and \"websocket\".<br />By default, this value is \"tcp\"."
msgstr "Protocol 指定与服务端交互时使用的协议。有效值为 \"tcp\"、\"kcp\"、\"quic\" 和 \"websocket\"。<br />默认值为 \"tcp\"。"

msgid "Proxy bind address"
msgstr "代理监听地址"

msgid "Proxy name"
msgstr "代理名称"

msgid "Proxy type"
msgstr "代理类型"

msgid "ProxyBindAddr specifies the address that the proxy binds to. This value may be the same as BindAddr.<br />By default, this value is \"0.0.0.0\"."
msgstr "ProxyBindAddr 指定代理绑定的地址。此值可以与 BindAddr 相同。<br />默认值为 \"0.0.0.0\"。"

msgid "ProxyType specifies the type of this proxy. Valid values include \"tcp\", \"udp\", \"http\", \"https\", \"stcp\" and \"xtcp\".<br />By default, this value is \"tcp\"."
msgstr "ProxyType 指定此代理的类型。有效值包括 \"tcp\"、\"udp\"、\"http\"、\"https\"、\"stcp\" 和 \"xtcp\"。<br />默认值为 \"tcp\"。"

msgid "QUIC bind port"
msgstr "QUIC 绑定端口"

msgid "Remote port"
msgstr "远程端口"

msgid "Respawn when crashed"
msgstr "崩溃后自动重启"

msgid "Role"
msgstr "角色"

msgid "Run daemon as group"
msgstr "守护进程运行用户组"

msgid "Run daemon as user"
msgstr "守护进程运行用户"

msgid "Running"
msgstr "运行中"

msgid "Server address"
msgstr "服务端地址"

msgid "Server Common Settings"
msgstr "服务端常规设置"

msgid "Server name"
msgstr "服务名称"

msgid "Server port"
msgstr "服务端端口"

msgid "Server Startup Settings"
msgstr "服务端启动设置"

msgid "ServerAddr specifies the address of the server to connect to.<br />By default, this value is \"127.0.0.1\"."
msgstr "ServerAddr 指定要连接的服务端地址。<br />默认值为 \"127.0.0.1\"。"

msgid "ServerPort specifies the port to connect to the server on.<br />By default, this value is 7000."
msgstr "ServerPort 指定连接服务端时使用的端口。<br />默认值为 7000。"

msgid "Sk"
msgstr "共享密钥"

msgid "SOCKS5 password"
msgstr "SOCKS5 密码"

msgid "SOCKS5 user"
msgstr "SOCKS5 用户名"

msgid "Start service"
msgstr "启动服务"

msgid "Stop service"
msgstr "停止服务"

msgid "Subdomain"
msgstr "子域名"

msgid "Subdomain host"
msgstr "子域名主域名"

msgid "SubDomainHost specifies the domain that will be attached to sub-domains requested by the client when using Vhost proxying. For example, if this value is set to \"frps.com\" and the client requested the subdomain \"test\", the resulting URL would be \"test.frps.com\".<br />By default, this value is \"\"."
msgstr "SubDomainHost 指定使用 Vhost 代理时附加到客户端请求子域名上的域名。例如，如果此值设置为 \"frps.com\"，客户端请求的子域名为 \"test\"，最终 URL 将为 \"test.frps.com\"。<br />默认值为 \"\"。"

msgid "TCP mux"
msgstr "TCP 连接复用"

msgid "TcpMux toggles TCP stream multiplexing. This allows multiple requests from a client to share a single TCP connection. If this value is true, the server must have TCP multiplexing enabled as well.<br />By default, this value is true."
msgstr "TcpMux 用于开启或关闭 TCP 连接复用，允许客户端的多个请求共享同一个 TCP 连接。如果此值为 true，服务端也必须启用 TCP 连接复用。<br />默认值为 true。"

msgid "TcpMux toggles TCP stream multiplexing. This allows multiple requests from a client to share a single TCP connection.<br />By default, this value is true."
msgstr "TcpMux 用于开启或关闭 TCP 连接复用，允许客户端的多个请求共享同一个 TCP 连接。<br />默认值为 true。"

msgid "This list can be used to specify INI parameters which have not been included in this LuCI."
msgstr "此列表可用于指定本 LuCI 页面未包含的 INI 参数。"

msgid "TLS"
msgstr "TLS"

msgid "TLS Enable specifies whether or not TLS should be used when communicating with the server."
msgstr "TLS Enable 指定与服务端通信时是否使用 TLS。"

msgid "Token"
msgstr "认证令牌"

msgid "Token specifies the authorization token used to authenticate keys received from clients. Clients must have a matching token to be authorized to use the server.<br />By default, this value is \"\"."
msgstr "Token 指定用于认证从客户端收到的密钥的授权令牌。客户端必须具有匹配的令牌才会被授权使用服务端。<br />默认值为 \"\"。"

msgid "Token specifies the authorization token used to create keys to be sent to the server. The server must have a matching token for authorization to succeed. <br />By default, this value is \"\"."
msgstr "Token 指定用于创建发送到服务端的密钥的授权令牌。服务端必须具有匹配的令牌，授权才能成功。<br />默认值为 \"\"。"

msgid "UDP bind port"
msgstr "UDP 绑定端口"

msgid "Unix domain socket path"
msgstr "Unix 域套接字路径"

msgid "UseCompression controls whether or not communication with the server will be compressed.<br />By default, this value is false."
msgstr "UseCompression 控制与服务端通信时是否启用压缩。<br />默认值为 false。"

msgid "UseEncryption controls whether or not communication with the server will be encrypted. Encryption is done using the tokens supplied in the server and client configuration.<br />By default, this value is false."
msgstr "UseEncryption 控制与服务端通信时是否加密。加密会使用服务端和客户端配置中提供的令牌。<br />默认值为 false。"

msgid "User"
msgstr "用户"

msgid "User specifies a prefix for proxy names to distinguish them from other clients. If this value is not \"\", proxy names will automatically be changed to \"{user}.{proxy_name}\".<br />By default, this value is \"\"."
msgstr "User 指定代理名称的前缀，用于区分其他客户端。如果此值不为 \"\"，代理名称将自动改为 \"{user}.{proxy_name}\"。<br />默认值为 \"\"。"

msgid "Vhost HTTP port"
msgstr "Vhost HTTP 端口"

msgid "Vhost HTTP timeout"
msgstr "Vhost HTTP 超时"

msgid "Vhost HTTPS port"
msgstr "Vhost HTTPS 端口"

msgid "VhostHttpPort specifies the port that the server listens for HTTP Vhost requests. If this value is 0, the server will not listen for HTTP requests.<br />By default, this value is 0."
msgstr "VhostHttpPort 指定服务端监听 HTTP Vhost 请求的端口。如果此值为 0，服务端将不会监听 HTTP 请求。<br />默认值为 0。"

msgid "VhostHttpsPort specifies the port that the server listens for HTTPS Vhost requests. If this value is 0, the server will not listen for HTTPS requests.<br />By default, this value is 0."
msgstr "VhostHttpsPort 指定服务端监听 HTTPS Vhost 请求的端口。如果此值为 0，服务端将不会监听 HTTPS 请求。<br />默认值为 0。"

msgid "VhostHttpTimeout specifies the response header timeout for the Vhost HTTP server, in seconds.<br />By default, this value is 60."
msgstr "VhostHttpTimeout 指定 Vhost HTTP 服务器的响应头超时时间，单位为秒。<br />默认值为 60。"

msgid "ProxyType specifies the type of this proxy. Valid values include \"tcp\", \"udp\", \"tcp_udp\", \"http\", \"https\", \"stcp\" and \"xtcp\".<br />By default, this value is \"tcp\"."
msgstr "ProxyType 指定此代理的类型。有效值包括 \"tcp\"、\"udp\"、\"tcp_udp\"、\"http\"、\"https\"、\"stcp\" 和 \"xtcp\"。<br />默认值为 \"tcp\"。"

msgid "TCP + UDP"
msgstr "TCP + UDP"
